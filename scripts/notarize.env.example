# Copy this file to scripts/notarize.env (which is gitignored) and fill it in.

# Your Developer ID Application identity. List available identities with:
#   security find-identity -v -p codesigning
DEVELOPER_ID="Developer ID Application: Your Name (TEAMID)"

# A notary credential profile, created once with:
#   xcrun notarytool store-credentials "baud-notary" \
#     --apple-id "you@example.com" --team-id "TEAMID" \
#     --password "app-specific-password"
NOTARY_PROFILE="baud-notary"
